{
  "version": 2,
  "framework": null,
  "outputDirectory": ".",
  "buildCommand": "echo 'no build'",
  "functions": {
    "api/**/*.js": { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/api/otp/send",       "destination": "/api/otp" },
    { "source": "/api/otp/verify",     "destination": "/api/otp" },
    { "source": "/api/invite/join",    "destination": "/api/invite/send" },
    { "source": "/",                   "destination": "/index.html" },
    { "source": "/connexion",          "destination": "/login.html" },
    { "source": "/espace-client",      "destination": "/dashboard.html" },
    { "source": "/administration",     "destination": "/admin.html" },
    { "source": "/join/:code",         "destination": "/join.html" },
    { "source": "/join/:code/(.*)",    "destination": "/join.html" }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" }
      ]
    }
  ]
}
