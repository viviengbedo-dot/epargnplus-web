# ══════════════════════════════════════════════════════════
#  Epargn+ — Variables d'environnement Vercel
#  Pays : Guinée (+224) · Bénin (+229) · Côte d'Ivoire (+225)
#  À configurer sur : https://vercel.com → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────
# Récupérez ces valeurs sur : https://supabase.com → Projet → Settings → API
#   - Project URL  → SUPABASE_URL
#   - service_role → SUPABASE_SERVICE_KEY  (jamais côté client !)

SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_KEY=votre_cle_service_role_supabase

# ── JWT ───────────────────────────────────────────────────
# Secret pour signer les tokens de session (≥ 32 caractères aléatoires)
# Commande : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=changez_moi_avec_une_valeur_aleatoire_forte

# ── Infobip SMS (international — recommandé pour multi-pays) ──
# Couvre Guinée (+224), Bénin (+229), Côte d'Ivoire (+225)
# Obtenez ces valeurs sur : https://portal.infobip.com → Developers → API Keys

INFOBIP_API_KEY=votre_cle_api_infobip
INFOBIP_BASE_URL=xxxxx.api.infobip.com
INFOBIP_FROM=EpargnPlus

# ── Sécurité OTP ─────────────────────────────────────────
# Secret HMAC pour les tokens OTP (≥ 32 caractères aléatoires)
# Commande : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

OTP_SECRET=changez_moi_avec_une_valeur_aleatoire_forte

# ══════════════════════════════════════════════════════════
#  NUMÉROS MARCHANDS EPARGN+ (à compléter avec vos vrais numéros)
#  Ces numéros sont définis directement dans dashboard.html → MERCHANT{}
#  Ils représentent le compte Mobile Money Epargn+ vers lequel
#  les utilisateurs effectuent leurs dépôts.
#
#  Format attendu par opérateur et pays :
#  orange.gn = numéro Orange Money Guinée de la plateforme
#  orange.ci = numéro Orange Money CI de la plateforme
#  mtn.gn    = numéro MTN Guinée
#  mtn.bj    = numéro MTN Bénin
#  mtn.ci    = numéro MTN CI
#  wave.*    = numéro Wave (selon pays)
#  moov.bj   = numéro Moov Bénin
#  moov.ci   = numéro Moov CI
#  celtiis.bj= numéro Celtiis Bénin
#  coris.ci  = numéro Coris Money CI
# ══════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════
#  MODE DÉMO SMS (quand INFOBIP_API_KEY n'est pas défini)
#  → L'OTP est visible dans les logs Vercel (Dashboard → Functions → Logs)
#  → Aucun SMS réel n'est envoyé
#  → La vérification HMAC reste active
# ══════════════════════════════════════════════════════════
